{
  "version": 2,
  "builds": [{ "src": "src/app.js", "use": "@vercel/node" }],
  "routes": [{ "src": "/(.*)", "dest": "src/app.js" }],
  "crons": [
    { "path": "/api/jobs/cleanup",       "schedule": "0 2 * * *" },
    { "path": "/api/jobs/stuck-builds",  "schedule": "0 * * * *" },
    { "path": "/api/jobs/subscriptions", "schedule": "0 3 * * *" }
  ]
}
